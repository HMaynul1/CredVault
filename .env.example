# NeonDB Postgres connection string
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/crdxcube?sslmode=require"

# Random 64-char secret for signing session JWTs
JWT_SECRET="generate-a-long-random-string"

# Cloudinary (for storing client-side ENCRYPTED attachment blobs only)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
